# infra/.env.example — copy to infra/.env for local dev
NEWELL_ENV=local
NEWELL_LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=newell
POSTGRES_PASSWORD=newell
POSTGRES_DB=newell
NEWELL_POSTGRES_DSN=postgresql+asyncpg://newell:newell@postgres:5432/newell

# Redis
NEWELL_REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=newell
MINIO_ROOT_PASSWORD=newell-secret
NEWELL_MINIO_ENDPOINT=minio:9000
NEWELL_MINIO_ACCESS_KEY=newell
NEWELL_MINIO_SECRET_KEY=newell-secret
NEWELL_MINIO_PUBLIC_ENDPOINT=localhost:9000
NEWELL_MINIO_BUCKET=newell-media

# Auth / Profile
NEWELL_JWT_SECRET=dev-only-change-me-1234567890-abcdefghijklmnopqrstuvwxyz
NEWELL_AUTH_URL=http://auth:8000
NEWELL_PROFILE_URL=http://profile:8000

# Media / AI Gateway / PlantCare
NEWELL_MEDIA_URL=http://media:8000
NEWELL_AI_GATEWAY_URL=http://ai_gateway:8000
NEWELL_PLANTCARE_URL=http://plantcare:8000
NEWELL_AI_PROVIDER=mock
